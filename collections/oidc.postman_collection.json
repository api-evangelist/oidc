    {
      "id": "a9f76b8c-9b32-4b03-8f21-d2e82788f4af",
      "name": "Authentication",
      "description": {
        "content": "Endpoints for authenticating end-users and obtaining authorization grants.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "9a5c427d-fa17-42c9-a93f-a48d463740b2",
          "name": "Authorization Endpoint",
          "request": {
            "name": "Authorization Endpoint",
            "description": {
              "content": "Performs authentication of the end-user. The authorization endpoint is used to interact with the resource owner and obtain an authorization grant. The endpoint handles the authentication flow and redirects back to the client with an authorization code or tokens depending on the response type.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "authorize"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "response_type",
                  "value": "<string>",
                  "description": "(Required) The value must include 'code' for the Authorization Code Flow, 'id_token' for the Implicit Flow, or 'code id_token' for the Hybrid Flow."
                },
                {
                  "disabled": false,
                  "key": "client_id",
                  "value": "<string>",
                  "description": "(Required) The client identifier issued during registration."
                },
                {
                  "disabled": false,
                  "key": "redirect_uri",
                  "value": "<uri>",
                  "description": "(Required) The redirection URI to which the response will be sent. Must exactly match one of the redirection URIs registered for the client."
                },
                {
                  "disabled": false,
                  "key": "scope",
                  "value": "<string>",
                  "description": "(Required) Space-delimited list of scopes. Must include 'openid' to indicate an OIDC request. May also include 'profile', 'email', 'address', and 'phone'."
                },
                {
                  "disabled": false,
                  "key": "state",
                  "value": "<string>",
                  "description": "An opaque value used by the client to maintain state between the request and callback. Recommended for CSRF protection."
                },
                {
                  "disabled": false,
                  "key": "nonce",
                  "value": "<string>",
                  "description": "A string value used to associate a client session with an ID Token and to mitigate replay attacks. Required for implicit flow."
                },
                {
                  "disabled": false,
                  "key": "prompt",
                  "value": "<string>",
                  "description": "Space-delimited list of values that specifies whether the authorization server prompts the end-user for reauthentication and consent."
                },
                {
                  "disabled": false,
                  "key": "login_hint",
                  "value": "<string>",
                  "description": "A hint to the authorization server about the login identifier the end-user might use."
                },
                {
                  "disabled": false,
                  "key": "acr_values",
                  "value": "<string>",
                  "description": "Requested Authentication Context Class Reference values."
                },
                {
                  "disabled": false,
                  "key": "code_challenge",
                  "value": "<string>",
                  "description": "PKCE code challenge derived from the code verifier."
                },
                {
                  "disabled": false,
                  "key": "code_challenge_method",
                  "value": "<string>",
                  "description": "Code challenge method used to derive the code challenge."
                }
              ],
              "variable": [
                {
                  "description": "The OIDC issuer domain",
                  "type": "any",
                  "value": "{{issuer}}",
                  "key": "issuer"
                }
              ]
            },
            "method": "GET",
            "auth": null
